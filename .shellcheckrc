# ShellCheck configuration for the ADOS-on-Ollama toolkit.
shell=bash
enable=all
# Follow `source`d files so helpers in scripts/lib are analysed; resolve
# `# shellcheck source=` paths relative to each script's own directory.
external-sources=true
source-path=SCRIPTDIR
# SC2312: "Consider invoking this command separately to avoid masking its return
# value" — too noisy for the log/pipe patterns used throughout.
disable=SC2312
# SC2310: "function invoked in an 'if'/&& condition so set -e is disabled" —
# that is exactly the intent for our boolean predicate functions (p_*, *_present,
# *_reachable). Testing their status is the whole point.
disable=SC2310
