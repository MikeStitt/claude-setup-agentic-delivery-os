#!/usr/bin/env bash
# ados-ollama-doctor — read-only preflight for the ADOS-on-Ollama runtime.
#
# Checks the host tools needed to install and run ADOS-on-Ollama and prints how
# to fix anything that is missing. Changes nothing.
#
# Usage: ados-ollama-doctor [--model <tag>] [-h|--help] [-V|--version]
# Exit:  0 = all required checks pass; 1 = one or more required checks failed.
set -Eeuo pipefail
set -o errtrace
shopt -s inherit_errexit 2>/dev/null || true
IFS=$'\n\t'

readonly APP_NAME="ados-ollama-doctor"
readonly APP_VERSION="0.1.0"
LOG_TAG="(${APP_NAME})"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/../scripts/lib/common.sh"

require_bash 4

GEMMA_MODEL="${GEMMA_MODEL:-gemma3}"
OLLAMA_HOST_URL="${OLLAMA_HOST_URL:-http://localhost:11434}"

_fail=0
_warn=0

# report <required|optional> <label> <fix-hint> <predicate-fn...>
report() {
  local level="$1" label="$2" fix="$3"
  shift 3
  if "$@" >/dev/null 2>&1; then
    printf '  %sPASS%s  %s\n' "${_C_GRN}" "${_C_RST}" "${label}"
    return 0
  fi
  if [[ "${level}" == "required" ]]; then
    ((_fail++)) || true
    printf '  %sFAIL%s  %s\n' "${_C_RED}" "${_C_RST}" "${label}"
  else
    ((_warn++)) || true
    printf '  %sWARN%s  %s\n' "${_C_YEL}" "${_C_RST}" "${label}"
  fi
  printf '        fix: %s\n' "${fix}"
  return 0
}

# --- Predicates (silent; exit status is the answer) ---
p_bash4() {
  local major
  major="$(bash -c 'printf %s "${BASH_VERSINFO[0]}"')"
  [[ "${major}" -ge 4 ]]
}
p_docker() { command -v docker && docker info; }
p_docker_sandbox() { docker sandbox --help; }
p_ollama_cli() { command -v ollama; }
p_ollama_up() { curl -fsS "${OLLAMA_HOST_URL}/api/tags"; }
p_gemma() { ollama list 2>/dev/null | grep -qiE 'gemma'; }
p_opencode() { command -v opencode; }
p_shellcheck() { command -v shellcheck; }
p_shfmt() { command -v shfmt; }
p_bats() { command -v bats; }

usage() {
  cat <<EOF
Usage: ${APP_NAME} [options]

Read-only preflight: checks the host tools needed to run ADOS-on-Ollama and
prints how to fix anything missing. Changes nothing.

Options:
  -h, --help          Show this help
  -V, --version       Show version
      --model <tag>   Gemma model tag to check for (default: ${GEMMA_MODEL})
EOF
}

main() {
  while (($#)); do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s %s\n' "${APP_NAME}" "${APP_VERSION}"
        exit 0
        ;;
      --model)
        shift
        GEMMA_MODEL="${1:?--model requires a tag}"
        ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done

  printf '%s — preflight\n\n' "${APP_NAME}"

  printf 'Runtime (required to run ADOS-on-Ollama):\n'
  report required "bash >= 4 on PATH" \
    "brew install bash; put \"\$(brew --prefix)/bin\" before /usr/bin on PATH" p_bash4
  report required "docker daemon running" \
    "start Docker Desktop" p_docker
  report required "docker sandbox subcommand" \
    "update Docker Desktop (the sandbox feature must be present)" p_docker_sandbox
  report required "ollama installed" \
    "brew install ollama  (or see https://ollama.com)" p_ollama_cli
  report required "ollama server reachable" \
    "start it: ollama serve" p_ollama_up
  report required "a Gemma model pulled" \
    "pull one: ollama pull ${GEMMA_MODEL}" p_gemma
  report required "opencode installed" \
    "install OpenCode: https://opencode.ai/docs" p_opencode

  printf '\nDev tools (only needed to build this toolkit):\n'
  report optional "shellcheck" "scripts/setup-dev.sh" p_shellcheck
  report optional "shfmt" "scripts/setup-dev.sh" p_shfmt
  report optional "bats" "scripts/setup-dev.sh" p_bats

  printf '\n'
  if [[ "${_fail}" -gt 0 ]]; then
    log_err "${_fail} required check(s) failed; ${_warn} warning(s)."
    return 1
  fi
  log_info "All required checks passed (${_warn} warning(s))."
  return 0
}

if [[ -z "${BASH_SOURCE[0]:-}" || "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
