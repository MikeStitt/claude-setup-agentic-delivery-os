#!/usr/bin/env bash
# ados-ollama — one entry point for installing and running ADOS-on-Ollama.
#
# Commands:
#   doctor      Read-only preflight (tools/ados-ollama-doctor)
#   install     Install ADOS into the target (scripts/install-ados.sh)
#   setup       Ensure Ollama + a Gemma model (scripts/setup-ollama.sh)
#   configure   Write the hybrid .opencode/opencode.jsonc (tools/gen-opencode-config)
#   sandbox     Launch OpenCode in a Docker sandbox (tools/ados-sandbox)
#   all         doctor (advisory) -> install -> setup -> configure
#
# Usage: ados-ollama <command> [--target <dir>] [--model <tag>]
#                     [--cloud-model <id>] [--num-ctx <n>] [-n] [-v]
#                     [-- <args forwarded to the sub-tool>]
#
# Exit: 0 ok; 2 usage. (Sub-tools own their own non-zero codes.)
set -Eeuo pipefail
set -o errtrace
shopt -s inherit_errexit 2>/dev/null || true
IFS=$'\n\t'

readonly APP_NAME="ados-ollama"
readonly APP_VERSION="0.1.0"
LOG_TAG="(${APP_NAME})"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/../scripts/lib/common.sh"

require_bash 4

readonly TOOLS="${SCRIPT_DIR}"
readonly SCRIPTS="${SCRIPT_DIR}/../scripts"

COMMAND=""
TARGET="."
MODEL=""
CLOUD_MODEL=""
NUM_CTX=""
PASSTHRU=()

# Argument arrays assembled from the parsed flags (filled in main).
DRY=()
VERBOSE_ARG=()
MODE_ARGS=() # --cloud-only / --local-only, forwarded to configure only

cmd_doctor() {
  local args=()
  [[ -n "${MODEL}" ]] && args+=(--model "${MODEL}")
  "${TOOLS}/ados-ollama-doctor" "${args[@]}"
}

cmd_install() {
  "${SCRIPTS}/install-ados.sh" --target "${TARGET}" "${DRY[@]}" "${VERBOSE_ARG[@]}" "${PASSTHRU[@]}"
}

cmd_setup() {
  local args=()
  [[ -n "${MODEL}" ]] && args+=(--model "${MODEL}")
  [[ -n "${NUM_CTX}" ]] && args+=(--num-ctx "${NUM_CTX}")
  "${SCRIPTS}/setup-ollama.sh" "${args[@]}" "${DRY[@]}" "${VERBOSE_ARG[@]}" "${PASSTHRU[@]}"
}

cmd_configure() {
  local args=()
  [[ -n "${MODEL}" ]] && args+=(--local-model "${MODEL}")
  [[ -n "${CLOUD_MODEL}" ]] && args+=(--cloud-model "${CLOUD_MODEL}")
  [[ -n "${NUM_CTX}" ]] && args+=(--num-ctx "${NUM_CTX}")
  "${TOOLS}/gen-opencode-config" --target "${TARGET}" "${args[@]}" "${MODE_ARGS[@]}" "${DRY[@]}" "${VERBOSE_ARG[@]}" "${PASSTHRU[@]}"
}

cmd_sandbox() {
  "${TOOLS}/ados-sandbox" --target "${TARGET}" "${DRY[@]}" "${VERBOSE_ARG[@]}" "${PASSTHRU[@]}"
}

cmd_all() {
  log_info "=== preflight ==="
  cmd_doctor || log_warn "preflight reported issues; continuing"
  log_info "=== install ADOS ==="
  cmd_install
  log_info "=== setup Ollama ==="
  cmd_setup
  log_info "=== write opencode config ==="
  cmd_configure
  log_info "Done. Launch with: ${APP_NAME} sandbox --target ${TARGET}"
}

usage() {
  cat <<EOF
Usage: ${APP_NAME} <command> [options] [-- <sub-tool args>]

Commands:
  doctor       Read-only preflight check
  install      Install ADOS into the target project
  setup        Ensure Ollama is running and a Gemma model is pulled
  configure    Write the hybrid .opencode/opencode.jsonc into the target
  sandbox      Launch OpenCode in an isolated Docker sandbox
  all          doctor (advisory) -> install -> setup -> configure

Options:
  --target <dir>      Target project (default: .)
  --model <tag>       Local Gemma model (forwarded to setup + configure)
  --cloud-model <id>  Cloud provider/model for high-stakes agents
  --num-ctx <n>       Local context window
  --cloud-only        All agents on the cloud model (configure/all)
  --local-only        All agents on the local Ollama model (configure/all)
  -n, --dry-run       Show what would be done without doing it
  -v, --verbose       Debug output
  -h, --help          Show this help
  -V, --version       Show version
  --                  Forward the remaining args to the sub-tool

Examples:
  ${APP_NAME} all --target . --model gemma3:27b
  ${APP_NAME} sandbox --target . -- --env ANTHROPIC_API_KEY=sk-...
EOF
}

main() {
  while (($#)); do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s %s\n' "${APP_NAME}" "${APP_VERSION}"
        exit 0
        ;;
      --target)
        shift
        TARGET="${1:?--target requires a dir}"
        ;;
      --model)
        shift
        MODEL="${1:?--model requires a tag}"
        ;;
      --cloud-model)
        shift
        CLOUD_MODEL="${1:?--cloud-model requires an id}"
        ;;
      --num-ctx)
        shift
        NUM_CTX="${1:?--num-ctx requires a value}"
        ;;
      --cloud-only) MODE_ARGS+=(--cloud-only) ;;
      --local-only) MODE_ARGS+=(--local-only) ;;
      -n | --dry-run) DRY_RUN=true ;;
      -v | --verbose) VERBOSE=true ;;
      --)
        shift
        PASSTHRU=("$@")
        break
        ;;
      doctor | install | setup | configure | sandbox | all)
        [[ -z "${COMMAND}" ]] || die "Multiple commands given: ${COMMAND}, $1"
        COMMAND="$1"
        ;;
      -*) die "Unknown option: $1" ;;
      *) die "Unknown command: $1" ;;
    esac
    shift
  done

  [[ -n "${COMMAND}" ]] || {
    usage
    die "No command given."
  }

  [[ "${DRY_RUN}" == "true" ]] && DRY=(--dry-run)
  [[ "${VERBOSE}" == "true" ]] && VERBOSE_ARG=(--verbose)

  "cmd_${COMMAND}"
}

if [[ -z "${BASH_SOURCE[0]:-}" || "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
