#!/usr/bin/env bash
# gen-opencode-config — write a target project's .opencode/opencode.jsonc with the
# hybrid model runtime: local Gemma (via Ollama) for high-volume/cheap agents and
# cloud models for high-stakes agents.
#
# Deterministic and idempotent: re-running with the same args yields identical
# bytes (no git churn). An existing file that DIFFERS is preserved (use --force to
# overwrite). No secrets are written — API keys stay {env:...} in your provider.
#
# Usage: gen-opencode-config --target <dir> [options]
#   --target <dir>       Project to write into (default: .)
#   --local-model <tag>  Ollama model for local agents (default: ${LOCAL_MODEL})
#   --cloud-model <id>   provider/model for cloud agents (default: ${CLOUD_MODEL})
#   --ollama-url <url>   baseURL for Ollama (default: ${OLLAMA_URL})
#   --num-ctx <n>        Context window for the local provider (default: ${NUM_CTX})
#   -f, --force          Overwrite an existing, differing config
#   -n, --dry-run / -v, --verbose / -h, --help / -V, --version
#
# Exit: 0 ok; 2 usage; 3 config.
set -Eeuo pipefail
set -o errtrace
shopt -s inherit_errexit 2>/dev/null || true
IFS=$'\n\t'

readonly APP_NAME="gen-opencode-config"
readonly APP_VERSION="0.1.0"
LOG_TAG="(${APP_NAME})"
readonly EXIT_CONFIG=3

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/../scripts/lib/common.sh"

require_bash 4

TARGET_DIR="."
LOCAL_MODEL="${LOCAL_MODEL:-gemma3}"
CLOUD_MODEL="${CLOUD_MODEL:-anthropic/claude-sonnet-4-6}"
# baseURL defaults to the Docker host gateway (the sandbox is the primary runtime,
# and `docker sandbox run` injects no env). For host-only runs, regenerate with
# --ollama-url http://localhost:11434/v1.
OLLAMA_URL="${OLLAMA_URL:-http://host.docker.internal:11434/v1}"
NUM_CTX="${NUM_CTX:-32000}"
FORCE=false
MODE="hybrid" # hybrid | cloud-only | local-only
MAIN_MODEL="" # top-level default model (computed from MODE in main)
SMALL_MODEL=""

# The hybrid map (edit here to retune). Cloud = high-stakes/tool-heavy tiers 1-2;
# local = high-volume/cheap tiers 3-5. NOTE: local models MUST support tool-calling
# (gemma3:1b does NOT) — use a tool-capable Gemma or move agents back to cloud.
CLOUD_AGENTS=(
  architect bootstrapper reviewer review-feedback-applier pm
  coder fixer plan-writer spec-writer test-plan-writer
  toolsmith designer doc-syncer pr-manager editor
)
LOCAL_AGENTS=(committer runner external-researcher image-generator image-reviewer)

die_config() {
  log_err "$@"
  exit "${EXIT_CONFIG}"
}

render_config() {
  local local_ref="ollama/${LOCAL_MODEL}"
  printf '// Generated by claude-setup-agentic-delivery-os (gen-opencode-config).\n'
  printf '// Hybrid runtime: local Gemma via Ollama + cloud for high-stakes agents.\n'
  printf '// baseURL targets the Docker host gateway; for host-only runs regenerate\n'
  printf '// with --ollama-url http://localhost:11434/v1.\n'
  printf '// Local agents need a TOOL-CAPABLE model (gemma3:1b cannot tool-call).\n'
  printf '{\n'
  # shellcheck disable=SC2016  # "$schema" is a literal JSON key, not a shell var
  printf '  "$schema": "https://opencode.ai/config.json",\n'
  printf '  "default_agent": "pm",\n'
  printf '  "model": "%s",\n' "${MAIN_MODEL}"
  printf '  "small_model": "%s",\n' "${SMALL_MODEL}"
  printf '  "provider": {\n'
  printf '    "ollama": {\n'
  printf '      "npm": "@ai-sdk/openai-compatible",\n'
  printf '      "name": "Ollama (local)",\n'
  printf '      "options": { "baseURL": "%s", "num_ctx": %s, "apiKey": "ollama" },\n' "${OLLAMA_URL}" "${NUM_CTX}"
  printf '      "models": { "%s": { "name": "Gemma (local via Ollama)", "tool_call": true, "limit": { "context": %s, "output": 8192 } } }\n' "${LOCAL_MODEL}" "${NUM_CTX}"
  printf '    }\n'
  printf '  },\n'
  printf '  "agent": {\n'

  local -a entries=()
  local a
  for a in "${CLOUD_AGENTS[@]}"; do
    entries+=("    \"${a}\": { \"model\": \"${CLOUD_MODEL}\" }")
  done
  for a in "${LOCAL_AGENTS[@]}"; do
    entries+=("    \"${a}\": { \"model\": \"${local_ref}\" }")
  done

  local i last=$((${#entries[@]} - 1))
  for i in "${!entries[@]}"; do
    if [[ "${i}" -lt "${last}" ]]; then
      printf '%s,\n' "${entries[i]}"
    else
      printf '%s\n' "${entries[i]}"
    fi
  done

  printf '  }\n'
  printf '}\n'
}

usage() {
  cat <<EOF
Usage: ${APP_NAME} --target <dir> [options]

Write <target>/.opencode/opencode.jsonc with the hybrid model map (local Gemma
via Ollama + cloud for high-stakes agents). Deterministic and idempotent; an
existing differing file is preserved unless --force.

Options:
  --target <dir>       Project to write into (default: .)
  --local-model <tag>  Ollama model for local agents (default: ${LOCAL_MODEL})
  --cloud-model <id>   provider/model for cloud agents (default: ${CLOUD_MODEL})
  --ollama-url <url>   baseURL for Ollama (default: ${OLLAMA_URL})
  --num-ctx <n>        Context window for the local provider (default: ${NUM_CTX})
  --cloud-only         Put ALL agents on the cloud model (no local agents)
  --local-only         Put ALL agents on the local Ollama model
  -f, --force          Overwrite an existing, differing config
  -n, --dry-run        Show what would be done without doing it
  -v, --verbose        Debug output
  -h, --help           Show this help
  -V, --version        Show version
EOF
}

main() {
  while (($#)); do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s %s\n' "${APP_NAME}" "${APP_VERSION}"
        exit 0
        ;;
      --target)
        shift
        TARGET_DIR="${1:?--target requires a dir}"
        ;;
      --local-model)
        shift
        LOCAL_MODEL="${1:?--local-model requires a tag}"
        ;;
      --cloud-model)
        shift
        CLOUD_MODEL="${1:?--cloud-model requires an id}"
        ;;
      --ollama-url)
        shift
        OLLAMA_URL="${1:?--ollama-url requires a url}"
        ;;
      --num-ctx)
        shift
        NUM_CTX="${1:?--num-ctx requires a value}"
        ;;
      --cloud-only) MODE="cloud-only" ;;
      --local-only) MODE="local-only" ;;
      -f | --force) FORCE=true ;;
      -n | --dry-run) DRY_RUN=true ;;
      -v | --verbose) VERBOSE=true ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done

  # Collapse the hybrid map for the single-runtime modes.
  case "${MODE}" in
    cloud-only)
      CLOUD_AGENTS+=("${LOCAL_AGENTS[@]}")
      LOCAL_AGENTS=()
      ;;
    local-only)
      LOCAL_AGENTS=("${CLOUD_AGENTS[@]}" "${LOCAL_AGENTS[@]}")
      CLOUD_AGENTS=()
      ;;
    hybrid) ;;
    *) die_config "Unknown mode: ${MODE}" ;;
  esac

  # Top-level default model OpenCode uses for the main session (so it does not
  # fall back to its built-in Claude default and demand an API key).
  local lref="ollama/${LOCAL_MODEL}"
  case "${MODE}" in
    local-only)
      MAIN_MODEL="${lref}"
      SMALL_MODEL="${lref}"
      ;;
    cloud-only)
      MAIN_MODEL="${CLOUD_MODEL}"
      SMALL_MODEL="${CLOUD_MODEL}"
      ;;
    *)
      MAIN_MODEL="${CLOUD_MODEL}"
      SMALL_MODEL="${lref}"
      ;;
  esac

  local target dest tmp
  target="$(cd "${TARGET_DIR}" 2>/dev/null && pwd -P)" \
    || die_config "Target directory not found: ${TARGET_DIR}"
  dest="${target}/.opencode/opencode.jsonc"

  tmp="$(mktemp)"
  render_config >"${tmp}"

  if [[ -f "${dest}" ]] && cmp -s "${tmp}" "${dest}"; then
    log_info "config unchanged: ${dest}"
    rm -f "${tmp}"
    return 0
  fi

  if [[ -f "${dest}" && "${FORCE}" != "true" ]]; then
    log_warn "config exists and differs: ${dest}"
    log_warn "preserving it (use --force to overwrite)."
    rm -f "${tmp}"
    return 0
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would write ${dest}:"
    sed 's/^/    /' "${tmp}"
    rm -f "${tmp}"
    return 0
  fi

  mkdir -p "${target}/.opencode"
  mv "${tmp}" "${dest}"
  log_info "wrote ${dest} (local=${LOCAL_MODEL}, cloud=${CLOUD_MODEL})"
}

if [[ -z "${BASH_SOURCE[0]:-}" || "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
