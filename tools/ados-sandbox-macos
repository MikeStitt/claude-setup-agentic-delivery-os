#!/usr/bin/env bash
# ados-sandbox-macos — run a command (default: opencode) under a macOS Seatbelt
# profile that confines WRITES to the target project, for macOS-native agent work
# that the Linux Docker sandbox can't do (building/debugging macOS binaries).
#
# EXPERIMENTAL / weaker than the Docker sandbox:
#   * sandbox-exec (Seatbelt) is deprecated by Apple (no stable public API).
#   * This confines file WRITES only — reads, network, and CPU are allowed. It is
#     NOT a VM and shares the host kernel. Prefer `ados-sandbox` (Docker) for real
#     isolation; use this only when you need macOS-native execution.
#
# Usage: ados-sandbox-macos --target <dir> [--allow-write <path>]... [-- <cmd ...>]
#   --target <dir>       Project whose tree may be written (default: .)
#   --allow-write <path> Extra writable subpath (repeatable)
#   -n, --dry-run / -v, --verbose / -h, --help / -V, --version
#
# Exit: 0 ok; 2 usage; 3 config.
set -Eeuo pipefail
set -o errtrace
shopt -s inherit_errexit 2>/dev/null || true
IFS=$'\n\t'

readonly APP_NAME="ados-sandbox-macos"
readonly APP_VERSION="0.1.0"
LOG_TAG="(${APP_NAME})"
readonly EXIT_CONFIG=3

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=scripts/lib/common.sh
source "${SCRIPT_DIR}/../scripts/lib/common.sh"

require_bash 4

TARGET_DIR="."
EXTRA_WRITES=()
CMD_ARGS=()
_PROFILE_TMP=""

die_config() {
  log_err "$@"
  exit "${EXIT_CONFIG}"
}

cleanup() {
  if [[ -n "${_PROFILE_TMP}" && -f "${_PROFILE_TMP}" ]]; then
    rm -f "${_PROFILE_TMP}"
  fi
}
trap cleanup EXIT

render_profile() {
  printf '(version 1)\n'
  printf ';; Generated by claude-setup-agentic-delivery-os (ados-sandbox-macos).\n'
  printf ';; allow-default + deny-writes-except-whitelist: reads/network/cpu are\n'
  printf ';; permitted; writes are confined to the project and necessary caches.\n'
  printf '(allow default)\n'
  printf '(deny file-write*)\n'
  printf '(allow file-write*\n'
  printf '  (subpath "%s")\n' "${TARGET_ABS}"
  printf '  (subpath "/private/var/folders")\n'
  printf '  (subpath "/private/tmp")\n'
  printf '  (subpath "/tmp")\n'
  printf '  (subpath "%s/.config/opencode")\n' "${HOME}"
  printf '  (subpath "%s/.ollama")\n' "${HOME}"
  printf '  (subpath "%s/.ados")\n' "${HOME}"
  local w
  for w in "${EXTRA_WRITES[@]}"; do printf '  (subpath "%s")\n' "${w}"; done
  printf '  (subpath "/dev"))\n'
}

usage() {
  cat <<EOF
Usage: ${APP_NAME} --target <dir> [--allow-write <path>]... [-- <cmd ...>]

Run a command (default: opencode) under a macOS Seatbelt profile that confines
file WRITES to the target project (+ temp and opencode/ollama/ados caches).
EXPERIMENTAL — sandbox-exec is deprecated and weaker than the Docker sandbox;
use ados-sandbox (Docker) for real isolation, this only for macOS-native work.

Options:
  --target <dir>        Project whose tree may be written (default: .)
  --allow-write <path>  Extra writable subpath (repeatable)
  -n, --dry-run         Print the profile and command without running
  -v, --verbose         Debug output
  -h, --help            Show this help
  -V, --version         Show version
EOF
}

main() {
  while (($#)); do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf '%s %s\n' "${APP_NAME}" "${APP_VERSION}"
        exit 0
        ;;
      --target)
        shift
        TARGET_DIR="${1:?--target requires a dir}"
        ;;
      --allow-write)
        shift
        EXTRA_WRITES+=("${1:?--allow-write requires a path}")
        ;;
      -n | --dry-run) DRY_RUN=true ;;
      -v | --verbose) VERBOSE=true ;;
      --)
        shift
        CMD_ARGS=("$@")
        break
        ;;
      *) die "Unknown option: $1" ;;
    esac
    shift
  done

  [[ "$(uname -s)" == "Darwin" ]] \
    || log_warn "Not macOS — sandbox-exec is unavailable here (this tool is macOS-only)."

  TARGET_ABS="$(cd "${TARGET_DIR}" 2>/dev/null && pwd -P)" \
    || die_config "Target directory not found: ${TARGET_DIR}"
  [[ "${#CMD_ARGS[@]}" -gt 0 ]] || CMD_ARGS=(opencode)

  # Space-joined for display (IFS is \n\t, so ${CMD_ARGS[*]} would use newlines).
  local cmd_str
  cmd_str="$(
    IFS=' '
    printf '%s' "${CMD_ARGS[*]}"
  )"

  log_info "Target:  ${TARGET_ABS}"
  log_info "Command: ${cmd_str}"

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Seatbelt profile:"
    render_profile | sed 's/^/    /'
    log_info "[DRY-RUN] Would execute: sandbox-exec -f <profile> ${cmd_str}"
    return 0
  fi

  require_cmd sandbox-exec
  _PROFILE_TMP="$(mktemp)"
  render_profile >"${_PROFILE_TMP}"
  log_info "Launching under Seatbelt confinement..."
  sandbox-exec -f "${_PROFILE_TMP}" "${CMD_ARGS[@]}"
}

if [[ -z "${BASH_SOURCE[0]:-}" || "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
